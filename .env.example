# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Stripe (publishable key — safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# App
VITE_APP_URL=https://markuce.com

# Optional: override RPC endpoints for Chainlink price feed reads
VITE_ETH_RPC_URL=https://eth.public-node.com
VITE_POLYGON_RPC_URL=https://polygon.llamarpc.com
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Supabase Edge Function secrets (set via `supabase secrets set`) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# WISE_API_KEY=...
# SUMSUB_APP_TOKEN=...
# SUMSUB_SECRET_KEY=...
# DASHBOARD_ORIGINS=https://markuce.com,http://localhost:5173
# HELIUS_API_KEY=...
# ALCHEMY_API_KEY=...
